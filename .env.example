# Copia questo file in .env.local e inserisci le tue credenziali Supabase.
# Su Vercel: Settings > Environment Variables (stessi nomi).
# IMPORTANTE: con Vite il prefisso DEVE essere VITE_ (non REACT_APP_).

VITE_SUPABASE_URL=https://tuo-progetto.supabase.co
VITE_SUPABASE_ANON_KEY=la-tua-anon-key-pubblica
